# Ylang environment variables — copy to .env or export in your shell.
# Never commit real API keys.
# Full reference: docs/configuration.md

# =============================================================================
# Storage
# =============================================================================
# SQLite database path (default: ~/.ylang/ylang.db)
# YLANG_STORAGE_PATH=~/.ylang/ylang.db

# =============================================================================
# MCP transport
# =============================================================================
# stdio (default, local subprocess) or http (streamable HTTP for remote clients)
# YLANG_TRANSPORT=stdio
# YLANG_HOST=0.0.0.0
# YLANG_PORT=8787
# Required when YLANG_TRANSPORT=http — use: openssl rand -hex 32
# YLANG_AUTH_TOKEN=your-secret-token

# =============================================================================
# LLM provider API keys
# Set a key to enable that provider's models in the default routing lists.
# Models without a key are skipped (skipped:no_key in startup report).
# =============================================================================
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
# PERPLEXITY_API_KEY=

# =============================================================================
# Model prioritization (comma-separated, left = highest priority)
# Override per activity; unset = use built-in defaults (see docs/configuration.md)
# =============================================================================
# YLANG_MODELS_CODE=anthropic/claude-3-5-sonnet-latest,openai/o3-mini,openai/gpt-4o,mistral/mistral-large-latest
# YLANG_MODELS_SEARCH=perplexity/sonar,openai/gpt-4o,anthropic/claude-3-5-sonnet-latest
# YLANG_MODELS_REASON=openai/o3-mini,anthropic/claude-3-5-sonnet-latest,openai/gpt-4o
# YLANG_MODELS_IMPROVE=anthropic/claude-3-5-sonnet-latest,openai/gpt-4o,mistral/mistral-small-latest
# YLANG_MODELS_OTHER=mistral/mistral-small-latest,openai/gpt-4o-mini,anthropic/claude-3-5-sonnet-latest

# =============================================================================
# Routing tuning
# =============================================================================
# Last model tried when all cloud routes fail (default: ollama/qwen2.5)
# YLANG_FALLBACK_MODEL=ollama/qwen2.5

# Cost tie-break among models within N ranks of the best (0 = strict quality-first)
# YLANG_QUALITY_BAND=0

# Skip a provider for N seconds after retryable failure (429, 5xx)
# YLANG_PROVIDER_COOLDOWN_SECONDS=60

# Rolling 24h spend cap; cloud models skipped when exceeded (unset = no cap)
# YLANG_DAILY_BUDGET_USD=5.00

# =============================================================================
# LiteLLM / Ollama (not read by Settings — passed through to LiteLLM)
# =============================================================================
# OLLAMA_API_BASE=http://localhost:11434
# OLLAMA_HOST=http://localhost:11434

# =============================================================================
# Cursor hooks (optional overrides)
# =============================================================================
# YLANG_HOOK_DISABLED=1
# YLANG_HOOK_MODEL=claude-sonnet-4-5
# YLANG_MCP_URL=http://127.0.0.1:8787/mcp

# =============================================================================
# Deprecated — use YLANG_MODELS_* lists instead
# =============================================================================
# YLANG_MODEL_CODE=
# YLANG_MODEL_SEARCH=
# YLANG_MODEL_REASON=
# YLANG_MODEL_OTHER=
