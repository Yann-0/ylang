# Ylang environment variables — copy to .env or export in your shell.
# Never commit real API keys.

# --- Storage ---
# SQLite database path (default: ~/.ylang/ylang.db)
# YLANG_STORAGE_PATH=~/.ylang/ylang.db

# --- MCP transport ---
# stdio (default, local subprocess) or http (streamable HTTP for remote clients)
# YLANG_TRANSPORT=stdio
# YLANG_HOST=0.0.0.0
# YLANG_PORT=8787
# Required when YLANG_TRANSPORT=http
# YLANG_AUTH_TOKEN=your-secret-token

# --- LLM provider API keys (optional; cloud models skipped when missing) ---
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# MISTRAL_API_KEY=
# PERPLEXITY_API_KEY=

# --- Model routing ---
# Comma-separated LiteLLM model lists per activity (quality-ordered)
# YLANG_MODELS_CODE=anthropic/claude-3-5-sonnet-latest,openai/gpt-4o
# YLANG_MODELS_SEARCH=perplexity/sonar,openai/gpt-4o
# YLANG_MODELS_REASON=openai/o3-mini,anthropic/claude-3-5-sonnet-latest
# YLANG_MODELS_IMPROVE=anthropic/claude-3-5-sonnet-latest,openai/gpt-4o
# YLANG_MODELS_OTHER=mistral/mistral-small-latest,openai/gpt-4o-mini

# Local fallback when cloud routes fail (default: ollama/qwen2.5)
# YLANG_FALLBACK_MODEL=ollama/qwen2.5

# Rank offset for cost tie-break within quality band (default: 0)
# YLANG_QUALITY_BAND=0

# Seconds to skip a provider after retryable failure (default: 60)
# YLANG_PROVIDER_COOLDOWN_SECONDS=60

# Optional rolling 24h spend cap in USD
# YLANG_DAILY_BUDGET_USD=5.00

# --- Cursor hooks (optional overrides) ---
# YLANG_HOOK_DISABLED=1
# YLANG_HOOK_MODEL=claude-sonnet-4-5
# YLANG_MCP_URL=http://127.0.0.1:8787/mcp
